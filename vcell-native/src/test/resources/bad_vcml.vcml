        <Parameter Name="kin_y2" Role="user defined" Unit="um">((chrH * 0.5) + (kinH * 0.5))</Parameter>
        <Parameter Name="L_kin_x2" Role="user defined" Unit="um">(x_mid - (KK_disSim / 2.0))</Parameter>
